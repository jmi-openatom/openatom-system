# build artifact
build/
target/
dist/
log/
uploads/
# 编译产物兜底：防止 IDE 异常把 class 输出到非 target 目录
*.class
${project.build.directory}/
# 保留备份目录结构但忽略内容
!uploads/export-backups/
uploads/export-backups/*

# AstrBot runtime data. Keep the OpenAtom plugin source deployable, but do not
# commit local runtime databases, logs, generated dashboard assets, QQ cache, etc.
astrbot/data/*
!astrbot/data/plugins/
astrbot/data/plugins/*
!astrbot/data/plugins/astrbot_plugin_openatom_api/
!astrbot/data/plugins/astrbot_plugin_openatom_api/**
astrbot/napcat/config/*
!astrbot/napcat/config/.gitkeep
astrbot/ntqq/*
!astrbot/ntqq/.gitkeep

# dependency package
node_modules/
.pnpm-store/

# macOS
.DS_Store
**/.DS_Store

# IDE
.idea/

# Xcode
xcuserdata/
DerivedData/
*.xcworkspace/xcuserdata/
