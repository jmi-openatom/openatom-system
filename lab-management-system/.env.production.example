# Local image tag written by GitHub Actions during deployment.
LAB_IMAGE_TAG=latest

LAB_FRONTEND_PORT=18091
LAB_SERVER_PORT=8091
JAVA_OPTS=-Xms256m -Xmx768m

LAB_MYSQL_DATABASE=db_lab_management
LAB_DB_USERNAME=lab_app
LAB_DB_PASSWORD=replace-with-strong-app-password
# Optional. If empty, production compose uses LAB_DB_PASSWORD as MySQL root password.
LAB_MYSQL_ROOT_PASSWORD=

# Optional. If empty, production compose uses LAB_DB_USERNAME/LAB_DB_PASSWORD.
LAB_RABBITMQ_USERNAME=
LAB_RABBITMQ_PASSWORD=
LAB_RABBITMQ_VHOST=/
LAB_RABBITMQ_PUBLIC_BIND=127.0.0.1
LAB_RABBITMQ_PUBLIC_PORT=5673
LAB_RABBITMQ_MANAGEMENT_BIND=127.0.0.1
LAB_RABBITMQ_MANAGEMENT_PORT=15673

LAB_JWT_SECRET=replace-with-at-least-32-random-chars
LAB_TOKEN_TTL_MINUTES=720
LAB_DEV_LOGIN_ENABLED=false

CMS_OAUTH_AUTHORIZE_URL=https://oauth.jmi-openatom.cn/api/v1/oauth/authorize
CMS_OAUTH_TOKEN_URL=https://oauth.jmi-openatom.cn/api/v1/oauth/token
CMS_OAUTH_USERINFO_URL=https://oauth.jmi-openatom.cn/api/v1/oauth/userinfo
CMS_OAUTH_CLIENT_ID=lab-lms
CMS_OAUTH_CLIENT_SECRET=replace-with-cms-oauth-secret
LAB_OAUTH_REDIRECT_URI=https://lab.jmi-openatom.cn/auth/callback
CMS_OAUTH_SCOPES=openid profile

LAB_MQ_EXCHANGE=openatom.lab.events
LAB_MQ_CLUB_SCORE_ROUTING_KEY=club.score.add

LAB_ATTENDANCE_STANDARD_TIME=09:00
LAB_ATTENDANCE_LATE_CUTOFF_TIME=09:30
LAB_ONSITE_SCORE_AWARD=2
LAB_AUTO_SCORE_AWARD=3
LAB_LATE_PENALTY=-5
LAB_ABSENT_PENALTY=-10
LAB_ALLOWED_CIDRS=127.0.0.1/32,::1/128

LAB_AI_ENABLED=false
LAB_AI_ENDPOINT=
LAB_AI_API_KEY=
LAB_AI_MODEL=gpt-4.1-mini
LAB_SANDBOX_ENDPOINT=
LAB_SANDBOX_TIMEOUT_MS=5000
